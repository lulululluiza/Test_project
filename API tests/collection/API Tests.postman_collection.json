              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "const token = pm.response.json()\r",
                  "\r",
                  "pm.test(\"Return type is a object\", () => {\r",
                  "    pm.expect(token).to.be.a('object')    \r",
                  "    pm.expect(token).to.haveOwnProperty('token')\r",
                  "    pm.expect(token.token).to.be.an('string')\r",
                  "})\r",
                  "\r",
